# Ollama configuration
OLLAMA_HOST=http://localhost:11434
# Default to the smaller 3B model — fast and tool-capable.
# Swap to llama3.1:8b for better reasoning if your machine handles it.
OLLAMA_MODEL=llama3.2:3b

# Agent configuration
MAX_AGENT_STEPS=12
LOG_LEVEL=INFO

# I/O paths (relative to project root — work on Windows and Linux)
INBOX_DIR=./inbox
OUTBOX_DIR=./outbox
MOCK_DATA_DIR=./data/mock
